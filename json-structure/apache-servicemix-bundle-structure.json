{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-servicemix/refs/heads/main/json-structure/apache-servicemix-bundle-structure.json",
  "description": "OSGi bundle in ServiceMix",
  "type": "object",
  "properties": {
    "id": {
      "type": "int32",
      "description": "Bundle identifier"
    },
    "name": {
      "type": "string",
      "description": "Bundle name"
    },
    "symbolicName": {
      "type": "string",
      "description": "Bundle symbolic name"
    },
    "version": {
      "type": "string",
      "description": "Bundle version"
    },
    "state": {
      "type": "string",
      "enum": [
        "INSTALLED",
        "RESOLVED",
        "STARTING",
        "ACTIVE",
        "STOPPING",
        "UNINSTALLED"
      ],
      "description": "Bundle state"
    },
    "location": {
      "type": "string",
      "description": "Bundle location URL"
    }
  },
  "name": "Bundle"
}